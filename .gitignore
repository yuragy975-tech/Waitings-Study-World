# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# 词典原始 CSV（63MB，不上 git，从 ECDICT 仓库重新下载即可）
/data/raw/

# 生成的 SQLite 词典：要部署到 Vercel 必须上 git（33MB，可接受）
# /data/ecdict.db   ← 不再 ignore

# 啃料音频文件：要部署到 Vercel 必须上 git（约 90MB）
# 临时缓存文件还是要忽略：
/public/listening-materials/**/_tmp.*
/public/listening-materials/**/_w_*

# IDE
.vscode/
.idea/
*.swp
